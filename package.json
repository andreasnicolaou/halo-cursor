{
  "name": "@andreasnicolaou/halo-cursor",
  "version": "1.0.1",
  "description": "Framework-agnostic animated cursor for Angular, React, Vue, and plain TypeScript apps.",
  "main": "dist/index.umd.js",
  "private": false,
  "types": "dist/types/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build:rollup": "rollup -c",
    "build": "npm run clean && npm run build:rollup",
    "test": "jest",
    "test:ci": "cross-env JEST_JUNIT_CLASSNAME=\"{filepath}\" jest --reporters=default --reporters=jest-junit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:bundle": "npx bundlewatch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint --fix"
  },
  "homepage": "https://andreasnicolaou.github.io/halo-cursor/",
  "repository": {
    "type": "git",
    "url": "https://github.com/andreasnicolaou/halo-cursor.git"
  },
  "bugs": {
    "url": "https://github.com/andreasnicolaou/halo-cursor/issues"
  },
  "author": {
    "name": "Andreas Nicolaou",
    "email": "anicolaou66@gmail.com"
  },
  "license": "MIT",
  "jest": {
    "transform": {
      "^.+\\.(ts)$": [
        "ts-jest"
      ]
    },
    "testEnvironment": "jsdom",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ]
  },
  "bundlewatch": {
    "files": [
      {
        "path": "dist/index.js",
        "maxSize": "4kB",
        "compression": "gzip"
      },
      {
        "path": "dist/index.cjs",
        "maxSize": "4kB",
        "compression": "gzip"
      },
      {
        "path": "dist/index.umd.js",
        "maxSize": "4kB",
        "compression": "gzip"
      },
      {
        "path": "dist/index.umd.min.js",
        "maxSize": "4kB",
        "compression": "gzip"
      }
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.1",
    "bundlewatch": "^0.4.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-junit": "^17.0.0",
    "prettier": "3.8.4",
    "rimraf": "^6.1.3",
    "rollup": "^4.62.2",
    "rollup-plugin-dts": "^6.4.1",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "halo-cursor",
    "custom-cursor",
    "animated-cursor",
    "cursor",
    "cursor-halo",
    "mouse-cursor",
    "pointer-tracking",
    "cursor-animation",
    "cursor-effect",
    "interactive-elements",
    "hover-effects",
    "hide-native-cursor",
    "web-animation",
    "frontend",
    "framework-agnostic",
    "typescript",
    "javascript",
    "react",
    "vue",
    "angular",
    "svelte",
    "umd",
    "esm"
  ]
}
